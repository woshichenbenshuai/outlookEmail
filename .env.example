# Flask 配置
# 可选：留空时会自动生成并持久化到 SECRET_KEY_FILE 指定位置
# 若手动设置，请至少 32 个字符，且不要使用弱口令（如 123 / password）
SECRET_KEY=
# 可选：SECRET_KEY 持久化文件路径（容器内路径）
SECRET_KEY_FILE=/app/data/secret_key

# 登录密码（默认：admin123，首次启动后会自动哈希存储）
# 建议首次启动后立即通过 Web 界面修改为强密码（至少8位）
LOGIN_USERNAME=admin
LOGIN_PASSWORD=admin123

# 应用配置
# 主机映射端口（服务器 5000 被占用时可改为 17001）
HOST_PORT=17001
PORT=5000
HOST=0.0.0.0
FLASK_ENV=production
# 可选：禁用定时任务（true/false）
DISABLE_SCHEDULER=false

# 数据库路径
DATABASE_PATH=data/outlook_accounts.db

# GPTMail 临时邮箱配置
GPTMAIL_BASE_URL=https://mail.chatgpt.org.uk
GPTMAIL_API_KEY=gpt-test

# DuckMail 临时邮箱配置
DUCKMAIL_BASE_URL=https://api.duckmail.sbs
DUCKMAIL_API_KEY=

# OAuth2 配置（可选）
# 留空时会使用内置默认 client_id 与 redirect_uri
# OAUTH_CLIENT_ID=6daa9f56-5e67-4cb6-ae52-ef89ef912d36
# OAUTH_REDIRECT_URI=http://localhost:8080
